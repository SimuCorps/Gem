# Test basic values
puts "=== Basic Values ===";
puts 42;
puts 3.14;
puts true;
puts false;
puts nil;

# Test arithmetic
puts "=== Arithmetic ===";
puts 10 + 5;
puts 10 - 3;
puts 6 * 7;
puts 20 / 4;
puts 17 % 5;
puts -42;

# Test comparisons
puts "=== Comparisons ===";
puts 5 == 5;
puts 5 == 3;
puts 7 > 3;
puts 3 > 7;
puts 3 < 7;
puts 7 < 3;

# Test logical operations
puts "=== Logical Operations ===";
puts !true;
puts !false;
puts !nil;
puts !!42;

# Test global variables
puts "=== Global Variables ===";
int a = 10;
int b = 20;
puts a;
puts b;
puts a + b;

# Test function definition and call
puts "=== Function Call ===";
def fibonacci(int n) int
  if (n <= 1)
    return n;
  else
    return fibonacci(n - 1) + fibonacci(n - 2);
  end
end

puts fibonacci(10); 