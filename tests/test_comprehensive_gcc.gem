# ============================================================================
# LOOP CONSTRUCTS
# ============================================================================
puts "--- Testing Loops ---";

# Basic while loop
puts "While loop test:";
int! i = 0;
while (i < 5)
    puts i;
    i = i + 1;
end

# While loop with complex condition
puts "While loop with complex condition:";
int! loopCounter = 0;
bool! keepGoing = true;
while (loopCounter < 10 and keepGoing)
    puts loopCounter;
    loopCounter = loopCounter + 1;
    if (loopCounter == 3)
        keepGoing = false;
    end
end

# Basic for loop
puts "For loop test:";
for (int! j = 0; j < 5; j = j + 1)
    puts j;
end

# For loop with different increment
puts "For loop with step 2:";
for (int! k = 0; k < 10; k = k + 2)
    puts k;
end

# For loop counting down
puts "For loop counting down:";
for (int! m = 5; m > 0; m = m - 1)
    puts m;
end

# Nested loops
puts "Nested loops:";
for (int! outer = 1; outer <= 3; outer = outer + 1)
    puts "Outer: #{outer}";
    for (int! inner = 1; inner <= 2; inner = inner + 1)
        puts "  Inner: #{inner}";
    end
end

# Loop with early termination
puts "Loop with early termination:";
int! n = 0;
while (n < 10)
    if (n == 5)
        n = 10;  # Force loop to end
    else
        puts n;
        n = n + 1;
    end
end

# Loop with mutable variables
puts "Loop modifying multiple variables:";
int! sum = 0;
int! product = 1;
for (int! val = 1; val <= 4; val = val + 1)
    sum = sum + val;
    product = product * val;
    puts "val: #{val}, sum: #{sum}, product: #{product}";
end

# While loop with string manipulation
puts "String building in loop:";
string! loopResult = "";
int! loopCount = 1;
while (loopCount <= 3)
    loopResult = loopResult + "Item" + "#{loopCount}" + " ";
    loopCount = loopCount + 1;
end
puts loopResult;

# ============================================================================
# FUNCTION DEFINITIONS AND CALLS
# ============================================================================
puts "--- Testing Functions ---";

# Simple function
def greet(string name) string
    return "Hello, " + name;
end

puts greet("Alice");

# Function with multiple parameters
def add(int a, int b) int
    return a + b;
end

puts add(5, 3);

# Function with nullable parameter
def greetOptional(string? name) string
    if (name == nil)
        return "Hello, stranger!";
    else
        return "Hello, " + name;
    end
end

puts greetOptional("Bob");
puts greetOptional(nil);

# Function with mixed parameter types
def formatMessage(string msg, int num, bool urgent) string
    string! prefix = "";
    if (urgent) 
        prefix = "URGENT: ";
    else
        prefix = "INFO: ";
    end
    return prefix + msg + " (" + "#{num}" + ")";
end

puts formatMessage("System update", 42, true);
puts formatMessage("Regular message", 10, false);

# Recursive function
def factorial(int n) int
    if (n <= 1)
        return 1;
    else
        return n * factorial(n - 1);
    end
end

puts factorial(5);  # 120

# Boolean returning function
def isEvenFunc(int num) bool
    int half = num / 2;
    return (half * 2) == num;
end

puts isEvenFunc(4);   # true
puts isEvenFunc(7);   # false

# Void function
def printInfo(string name, int age) void
    puts "Name: " + name;
    puts "Age: " + "#{age}";
end

printInfo("Charlie", 30);

# Function with complex logic
def getGrade(int score) string
    if (score >= 90)
        return "A";
    elsif (score >= 80)
        return "B";
    elsif (score >= 70)
        return "C";
    elsif (score >= 60)
        return "D";
    else
        return "F";
    end
end

puts getGrade(95);
puts getGrade(75);
puts getGrade(55);

# ============================================================================
# CLOSURES AND FIRST-CLASS FUNCTIONS
# ============================================================================
puts "--- Testing Closures ---";

# Basic closure
def makeCounter() func
    int! count = 0;
    
    def increment() int
        count = count + 1;
        return count;
    end
    
    return increment;
end

func counter = makeCounter();
puts counter();  # 1
puts counter();  # 2
puts counter();  # 3

# Function returning function with parameters
def makeMultiplier(int factor) func
    def multiply(int x) int
        return x * factor;
    end
    return multiply;
end

func double = makeMultiplier(2);
func triple = makeMultiplier(3);

puts double(5);   # 10
puts triple(5);   # 15
puts double(10);  # 20

# ============================================================================
# SCOPE MANAGEMENT
# ============================================================================
puts "--- Testing Scopes ---";

# Global scope
string scopeGlobal = "global";
string! scopeMutableGlobal = "mutable global";

puts scopeGlobal;
puts scopeMutableGlobal;

# Basic begin/end block
begin
    string scopeLocal = "local";
    string! scopeMutableLocal = "mutable local";
    puts scopeGlobal;  # Access global from local scope
    puts scopeMutableGlobal;
    puts scopeLocal;
    puts scopeMutableLocal;
    
    # Modify mutable variable
    scopeMutableLocal = "modified local";
    puts scopeMutableLocal;
end

# Variables from block are not accessible here
puts scopeGlobal;
scopeMutableGlobal = "modified global";
puts scopeMutableGlobal;

# Nested scopes
begin
    string outerLocal = "outer";
    int outerNum = 42;
    puts outerLocal;
    puts outerNum;
    
    begin
        string innerLocal = "inner";
        int innerNum = 24;
        puts scopeGlobal;      # Access global
        puts outerLocal;  # Access outer scope
        puts innerLocal;  # Access current scope
        puts outerNum;
        puts innerNum;
        
        # Modify global from nested scope
        scopeMutableGlobal = "modified from nested";
        
        begin
            string deepLocal = "deep";
            puts scopeGlobal;
            puts outerLocal;
            puts innerLocal;
            puts deepLocal;
            puts outerNum;
            puts innerNum;
        end
    end
    
    puts outerLocal;  # Still accessible
    puts outerNum;
end

puts scopeMutableGlobal;  # Should show modification from nested scope

# Scope with functions
def testScopeFunction() void
    string functionLocal = "function local";
    puts functionLocal;
    puts scopeGlobal;  # Access global from function
    
    begin
        string blockInFunction = "block in function";
        puts functionLocal;     # Access function scope
        puts blockInFunction;   # Access block scope
        puts scopeGlobal;           # Access global scope
    end
end

testScopeFunction();

# Variable shadowing
string shadowTest = "global shadow";
puts shadowTest;

begin
    string shadowTest = "local shadow";  # Shadows global
    puts shadowTest;  # Should print local version
    
    begin
        string shadowTest = "nested shadow";  # Shadows local
        puts shadowTest;  # Should print nested version
    end
    
    puts shadowTest;  # Should print local version again
end

puts shadowTest;  # Should print global version

# ============================================================================
# CLASSES AND OBJECTS
# ============================================================================
puts "--- Testing Classes ---";

# Basic class definition
class Person
    def init(string name, int age) void
        this.name = name;
        this.age = age;
        this.nickname = nil; # nullable field
    end
    
    def introduce() string
        return "Hi, I'm " + this.name;
    end
    
    def haveBirthday() int
        this.age = this.age + 1;
        return this.age;
    end
    
    def isAdult() bool
        return this.age >= 18;
    end
    
    def setNickname(string? nick) void
        this.nickname = nick;
    end
    
    def getNickname() string
        if (this.nickname == nil)
            return "No nickname";
        else
            return "" + this.nickname;
        end
    end
end

# Create and use objects
obj person1 = Person("Alice", 25);
puts person1.introduce();
puts person1.haveBirthday();
puts person1.isAdult();

# Test nullable fields
puts person1.getNickname();
person1.setNickname("Ace");
puts person1.getNickname();

# Multiple objects
obj person2 = Person("Bob", 17);
puts person2.introduce();
puts person2.isAdult();

# Class with more complex methods
class Calculator
    def init() void
        this.result = 0;
    end
    
    def add(int value) int
        this.result = this.result + value;
        return this.result;
    end
    
    def multiply(int value) int
        this.result = this.result * value;
        return this.result;
    end
    
    def getResult() int
        return this.result;
    end
    
    def reset() void
        this.result = 0;
    end
end

obj calc = Calculator();
puts calc.add(10);      # 10
puts calc.multiply(3);  # 30
puts calc.add(5);       # 35
puts calc.getResult();  # 35
calc.reset();
puts calc.getResult();  # 0

# ============================================================================
# INHERITANCE AND SUPER KEYWORD
# ============================================================================
puts "--- Testing Inheritance ---";

# Base class
class Animal
    def init(string name) void
        this.name = name;
        this.owner = nil; # nullable field
    end
    
    def speak() string
        return this.name + " makes a sound";
    end
    
    def getType() string
        return "animal";
    end
    
    def setOwner(string? ownerName) void
        this.owner = ownerName;
    end
    
    def getOwner() string
        if (this.owner == nil)
            return "No owner";
        else
            return "" + this.owner;
        end
    end
    
    def introduce() string
        return "This is " + this.name + ", a " + this.getType();
    end
end

# Derived class
class Dog < Animal
    def init(string name, string breed) void
        super.init(name);
        this.breed = breed;
    end
    
    def speak() string
        return this.name + " barks";
    end
    
    def getType() string
        return "dog";
    end
    
    def isGoodBoy() bool
        return true;
    end
    
    def getBreed() string
        return this.breed;
    end
    
    def fullIntroduction() string
        return super.introduce() + " of breed " + this.breed;
    end
end

# Another derived class
class Cat < Animal
    def init(string name, bool isIndoor) void
        super.init(name);
        this.isIndoor = isIndoor;
    end
    
    def speak() string
        return this.name + " meows";
    end
    
    def getType() string
        return "cat";
    end
    
    def isIndoorCat() bool
        return this.isIndoor;
    end
    
    def hunt() string
        if (this.isIndoor)
            return this.name + " hunts toy mice";
        else
            return this.name + " hunts real mice";
        end
    end
end

# Test base class
obj animal = Animal("Fluffy");
puts animal.speak();
puts animal.getType();
puts animal.introduce();
puts animal.getOwner();
animal.setOwner("John");
puts animal.getOwner();

# Test derived classes
obj dog = Dog("Rex", "Golden Retriever");
puts dog.speak();      # Overridden method
puts dog.getType();    # Overridden method
puts dog.getBreed();
puts dog.isGoodBoy();
puts dog.introduce();  # Uses inherited method
puts dog.fullIntroduction(); # Uses super

obj cat = Cat("Whiskers", true);
puts cat.speak();
puts cat.getType();
puts cat.isIndoorCat();
puts cat.hunt();
puts cat.introduce();

# Test polymorphism
obj pet1 = Dog("Buddy", "Labrador");
obj pet2 = Cat("Mittens", false);

puts pet1.speak();  # Dog's speak method
puts pet2.speak();  # Cat's speak method
puts pet1.getType(); # Dog's getType method
puts pet2.getType(); # Cat's getType method

