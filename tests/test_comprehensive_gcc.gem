# Comprehensive Test for GEM Language - All Features
puts "=== COMPREHENSIVE GEM LANGUAGE TEST ===";

# ============================================================================
# BASIC DATA TYPES AND LITERALS
# ============================================================================
puts "--- Testing Basic Data Types ---";

# Integer literals
puts 42;
puts -123;
puts 0;
puts 999999;

# Floating point numbers
puts 3.14159;
puts -2.5;
puts 0.0;
puts 123.456;

# Boolean literals
puts true;
puts false;

# Nil literal
puts nil;

# String literals
puts "Hello, World!";
puts "Empty string: ";
puts "String with spaces";
puts "String with numbers: 123";
puts "String with symbols: !@#$%^&*()";

# ============================================================================
# VARIABLE DECLARATIONS AND MUTABILITY
# ============================================================================
puts "--- Testing Variables and Mutability ---";

# Immutable variables (default)
int age = 25;
string name = "Alice";
bool isActive = true;

puts age;
puts name;
puts isActive;

# Mutable variables (with ! suffix)
int! counter = 0;
string! message = "Hello";
bool! flag = false;

puts counter;
puts message;
puts flag;

# Reassignment of mutable variables
counter = 100;
message = "Updated message";
flag = true;

puts counter;
puts message;
puts flag;

# Multiple assignments
counter = counter + 50;
message = message + " - appended";

puts counter;
puts message;

# Test mut keyword syntax
mut int mutCounter = 42;
mut string mutMessage = "Hello";
mut bool mutFlag = true;

puts mutCounter;
puts mutMessage;
puts mutFlag;

mutCounter = 100;
mutMessage = "Updated";
mutFlag = false;

puts mutCounter;
puts mutMessage;
puts mutFlag;

# ============================================================================
# NULLABLE TYPES
# ============================================================================
puts "--- Testing Nullable Types ---";

# Nullable variables (with ? suffix)
string? optionalName = "Bob";
int? optionalAge = nil;
bool? optionalFlag = nil;

puts optionalName;
puts optionalAge;
puts optionalFlag;

# Mutable and nullable (with ?! suffix)
string?! mutableOptional = nil;
int?! mutableOptionalCount = 50;

puts mutableOptional;
puts mutableOptionalCount;

# Assigning values to nullable variables
mutableOptional = "Now has value";
mutableOptionalCount = nil;

puts mutableOptional;
puts mutableOptionalCount;

# Nil checking
if (optionalName != nil)
    puts "optionalName has a value";
else
    puts "optionalName is nil";
end

if (optionalAge == nil)
    puts "optionalAge is nil";
else
    puts "optionalAge has a value";
end

# Test mut with nullable types
mut int? nullable_counter = nil;
mut string? nullable_message = nil;

puts nullable_counter;
puts nullable_message;

nullable_counter = 50;
nullable_message = "Not nil anymore";

puts nullable_counter;
puts nullable_message;

# ============================================================================
# ARITHMETIC OPERATIONS
# ============================================================================
puts "--- Testing Arithmetic ---";

# Basic arithmetic
puts 5 + 3;        # Addition
puts 10 - 4;       # Subtraction
puts 6 * 7;        # Multiplication
puts 15 / 3;       # Division
puts 17 % 5;       # Modulo

# Order of operations
puts 2 + 3 * 4;    # Should be 14 (3*4 first, then +2)
puts (2 + 3) * 4;  # Should be 20 (parentheses first)

# Negative numbers
puts -5 + 3;       # Should be -2
puts -(-5);        # Should be 5

# Floating point arithmetic
puts 3.14 + 2.86;  # Should be 6.0
puts 10.5 / 2.0;   # Should be 5.25

# With variables
int x = 10;
int y = 5;
puts x + y;        # 15
puts x - y;        # 5
puts x * y;        # 50
puts x / y;        # 2
puts x % y;        # 0

# Complex expressions
int a = 2;
int b = 3;
int c = 4;
puts a + b * c;    # Should be 14
puts (a + b) * c;  # Should be 20
puts a * b + c;    # Should be 10

# Mutable variable arithmetic
int! result = 0;
result = result + 10;
result = result * 2;
result = result - 5;
puts result;       # Should be 15

# ============================================================================
# MODULO OPERATOR COMPREHENSIVE TESTS
# ============================================================================
puts "--- Testing Modulo Operator ---";

# Basic modulo operations
puts 10 % 3;    # 1
puts 15 % 4;    # 3
puts 20 % 5;    # 0
puts 7 % 2;     # 1
puts 8 % 2;     # 0

# Modulo with variables
int dividend = 17;
int divisor = 5;
int remainder = dividend % divisor;
puts remainder;  # 2

# Modulo in expressions
puts (10 + 5) % 4;    # 15 % 4 = 3
puts 20 % (3 + 2);    # 20 % 5 = 0
puts (7 * 3) % 8;     # 21 % 8 = 5

# Even/odd detection using modulo
def isEven(int num) bool
    return num % 2 == 0;
end

puts isEven(4);   # true
puts isEven(7);   # false

# ============================================================================
# COMPARISON OPERATORS
# ============================================================================
puts "--- Testing Comparisons ---";

# Equality comparisons
puts 5 == 5;       # true
puts 5 == 3;       # false
puts 5 != 3;       # true
puts 5 != 5;       # false

# Numeric comparisons
puts 7 > 3;        # true
puts 3 > 7;        # false
puts 2 < 8;        # true
puts 8 < 2;        # false
puts 5 >= 5;       # true
puts 5 >= 3;       # true
puts 3 >= 5;       # false
puts 3 <= 7;       # true
puts 7 <= 3;       # false
puts 5 <= 5;       # true

# String comparisons
puts "hello" == "hello";  # true
puts "hello" == "world";  # false
puts "hello" != "world";  # true

# Boolean comparisons
puts true == true;        # true
puts false == false;      # true
puts true == false;       # false
puts true != false;       # true

# Nil comparisons
puts nil == nil;          # true
puts nil != nil;          # false

# Variable comparisons
int compA = 10;
int compB = 20;
int compC = 10;

puts compA < compB;        # true
puts compA > compB;        # false
puts compA == compC;       # true
puts compA != compB;       # true

# Floating point comparisons
puts 3.14 > 3.0;   # true
puts 2.5 == 2.5;   # true
puts 1.0 < 1.1;    # true

# Complex expressions in comparisons
puts (5 + 3) == (2 * 4);  # true (both equal 8)
puts (10 - 2) > (3 * 2);  # true (8 > 6)

# ============================================================================
# LOGICAL OPERATORS
# ============================================================================
puts "--- Testing Logical Operators ---";

# Basic logical AND
puts true and true;    # true
puts true and false;   # false
puts false and true;   # false
puts false and false;  # false

# Basic logical OR
puts true or true;     # true
puts true or false;    # true
puts false or true;    # true
puts false or false;   # false

# Logical NOT
puts !true;            # false
puts !false;           # true
puts !nil;             # true (nil is falsy)

# Logical operations with variables
bool flag1 = true;
bool flag2 = false;
bool flag3 = true;

puts flag1 and flag2;  # false
puts flag1 or flag2;   # true
puts !flag2;           # true

# Complex logical expressions
puts flag1 and flag3;  # true
puts flag2 or flag3;   # true
puts !flag1 and flag2; # false
puts flag1 or !flag2;  # true

# Logical operations with comparisons
int logX = 10;
int logY = 5;
int logZ = 15;

puts logX > logY and logY < logZ;  # true and true = true
puts logX < logY or logY < logZ;   # false or true = true
puts !(logX == logY);              # !(false) = true

# Nested logical expressions
puts (logX > logY) and (logZ > logX) and (logY > 0);  # true and true and true = true
puts (logX < logY) or (logZ < logX) or (logY == 5);   # false or false or true = true

# ============================================================================
# TERNARY OPERATOR
# ============================================================================
puts "--- Testing Ternary Operator ---";

# Basic ternary operations
puts true ? "yes" : "no";     # Should print "yes"
puts false ? "yes" : "no";    # Should print "no"

# Ternary with numbers
puts true ? 42 : 0;           # Should print 42
puts false ? 42 : 0;          # Should print 0

# Ternary with expressions
int ternX = 10;
int ternY = 5;
puts ternX > ternY ? "x is greater" : "y is greater or equal";
puts ternX < ternY ? "x is less" : "y is less or equal";

# Ternary with variables
bool! condition = true;
string! ternResult = condition ? "true branch" : "false branch";
puts ternResult;

condition = false;
ternResult = condition ? "true branch" : "false branch";
puts ternResult;

# Nested ternary (right associative)
int! score = 85;
string! grade = score >= 90 ? "A" : score >= 80 ? "B" : score >= 70 ? "C" : "F";
puts grade;  # Should print "B"

# Ternary in expressions
int ternA = 10;
int ternB = 20;
int max = ternA > ternB ? ternA : ternB;
puts max;  # Should print 20

# Ternary with nullable types
string?! optionalText = nil;
string! displayText = optionalText != nil ? "found text" : "default text";
puts displayText;  # Should print "default text"

optionalText = "actual text";
displayText = optionalText != nil ? "found text" : "default text";
puts displayText;  # Should print "found text"

